@page "/"
@using elyra.Services.AiQuery
@using elyra.Services.AiInsights
@using elyra.Services.DemoData
@implements IAsyncDisposable

<PageTitle>Elyra Dashboard</PageTitle>

<main class="dashboard-page">
    <TopBar OnAskPrompt="HandleAskPromptAsync"
            LiveModeEnabled="@LiveModeEnabled"
            OnLiveModeChanged="HandleLiveModeChangedAsync" />

    <section class="dashboard-main">
        <div class="dashboard-left">
            <KpiCardsSection Metrics="@Kpis" />
            <SmartGridSection Transactions="@VisibleTransactions"
                              HighlightedTransactionIds="@FlaggedTransactionIds"
                              OnCurrentViewChanged="HandleCurrentViewChangedAsync" />
        </div>
        <AiAssistantSidebar Conversation="@Conversation"
                            QueryResponse="@LatestQueryResponse"
                            Insights="@Insights"
                            OnSummarizeCurrentView="SummarizeCurrentViewAsync"
                            OnDetectAnomalies="DetectAnomaliesAsync" />
    </section>
</main>

@code {
    private readonly List<TransactionRecord> AllTransactions = [];
    private IReadOnlyList<TransactionRecord> VisibleTransactions = Array.Empty<TransactionRecord>();
    private IReadOnlyList<TransactionRecord> CurrentGridView = Array.Empty<TransactionRecord>();
    private AiQueryResponse? LatestQueryResponse;
    private readonly List<AiInsightMessage> Insights = [];
    private IReadOnlySet<string> FlaggedTransactionIds = new HashSet<string>();
    private AiQueryInterpretation? ActiveQueryInterpretation;
    private bool LiveModeEnabled;
    private int _liveSequence = 184200;
    private CancellationTokenSource? _liveModeCts;
    private readonly List<KpiMetric> Kpis = [];

    private readonly List<AiMessage> Conversation =
    [
        new() { Sender = "User", Message = "Why did failed payments increase today?" },
        new() { Sender = "Elyra AI", Message = "Failure rate is up 1.8% mostly from card acquirer retries at Camden Mobility Co and Manchester Tech Supplies in the last 2 hours." },
        new() { Sender = "User", Message = "Any fraud patterns I should know?" },
        new() { Sender = "Elyra AI", Message = "Three failed Faster Payments over £3k have risk scores above 75. Sheffield Telecom Retail is the strongest anomaly cluster." }
    ];

    protected override void OnInitialized()
    {
        AllTransactions.AddRange(TransactionDataFactory.GenerateSeedData(DateTime.Now, 520));
        _liveSequence = ExtractHighestSequence(AllTransactions);
        VisibleTransactions = AllTransactions;
        CurrentGridView = VisibleTransactions;
        RebuildKpis();
    }

    private Task HandleAskPromptAsync(string prompt)
    {
        var interpretation = AiQueryParser.Parse(prompt);
        var executionResult = AiQueryExecutor.Execute(interpretation, AllTransactions, DateTime.Now);

        ActiveQueryInterpretation = interpretation;
        VisibleTransactions = executionResult.Rows;
        CurrentGridView = executionResult.Rows;
        FlaggedTransactionIds = new HashSet<string>();
        LatestQueryResponse = AiQueryResponseFormatter.Format(interpretation, executionResult);
        RebuildKpis();

        return Task.CompletedTask;
    }

    private Task HandleCurrentViewChangedAsync(IReadOnlyList<TransactionRecord> rows)
    {
        CurrentGridView = rows;
        return Task.CompletedTask;
    }

    private Task HandleLiveModeChangedAsync(bool isEnabled)
    {
        if (LiveModeEnabled == isEnabled)
        {
            return Task.CompletedTask;
        }

        LiveModeEnabled = isEnabled;
        if (LiveModeEnabled)
        {
            StartLiveMode();
        }
        else
        {
            StopLiveMode();
        }

        return Task.CompletedTask;
    }

    private Task SummarizeCurrentViewAsync()
    {
        var summary = AiInsightsEngine.SummarizeCurrentView(CurrentGridView, DateTime.Now);
        Insights.Insert(0, summary);
        TrimInsights();
        return Task.CompletedTask;
    }

    private Task DetectAnomaliesAsync()
    {
        var anomalyResult = AiInsightsEngine.DetectAnomalies(CurrentGridView, DateTime.Now);
        FlaggedTransactionIds = anomalyResult.FlaggedTransactionIds;
        Insights.Insert(0, anomalyResult.Insight);
        TrimInsights();
        return Task.CompletedTask;
    }

    private void TrimInsights()
    {
        while (Insights.Count > 8)
        {
            Insights.RemoveAt(Insights.Count - 1);
        }
    }

    private void StartLiveMode()
    {
        StopLiveMode();
        _liveModeCts = new CancellationTokenSource();
        _ = RunLiveModeLoopAsync(_liveModeCts.Token);
    }

    private void StopLiveMode()
    {
        if (_liveModeCts is null)
        {
            return;
        }

        _liveModeCts.Cancel();
        _liveModeCts.Dispose();
        _liveModeCts = null;
    }

    private async Task RunLiveModeLoopAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(4));
        while (!cancellationToken.IsCancellationRequested && await timer.WaitForNextTickAsync(cancellationToken))
        {
            await InvokeAsync(() =>
            {
                InjectLiveTransaction();
                StateHasChanged();
            });
        }
    }

    private void InjectLiveTransaction()
    {
        _liveSequence++;
        var now = DateTime.Now;
        var transaction = TransactionDataFactory.CreateLiveTransaction(now, _liveSequence);
        AllTransactions.Insert(0, transaction);

        if (ActiveQueryInterpretation is not null)
        {
            var execution = AiQueryExecutor.Execute(ActiveQueryInterpretation, AllTransactions, now);
            VisibleTransactions = execution.Rows;
        }
        else
        {
            VisibleTransactions = AllTransactions;
        }

        RebuildKpis();
        AddLiveNotableEvent(transaction, now);
    }

    private void AddLiveNotableEvent(TransactionRecord transaction, DateTime now)
    {
        Insights.Insert(0, new AiInsightMessage
        {
            Timestamp = now,
            Title = "Live Feed",
            Severity = "info",
            Message = $"{transaction.TransactionId} ingested for {transaction.Merchant} via {transaction.Channel} ({transaction.Country}) at £{transaction.Amount:N2}."
        });

        var isNotable = transaction.Status == "Failed" &&
                        (transaction.RiskScore >= 82 || transaction.Amount >= 4500m || transaction.RetryCount >= 2);
        if (isNotable)
        {
            Insights.Insert(0, new AiInsightMessage
            {
                Timestamp = now,
                Title = "Live Event",
                Severity = "warning",
                Message = $"{transaction.TransactionId} ({transaction.Merchant}) flagged: {transaction.DeclineReason}, " +
                          $"issuer code {transaction.IssuerResponseCode}, retry {transaction.RetryCount}, channel {transaction.Channel}."
            });
        }
        TrimInsights();
    }

    private void RebuildKpis()
    {
        Kpis.Clear();

        var ordered = AllTransactions.OrderByDescending(x => x.Timestamp).ToList();
        var currentWindow = ordered.Take(120).ToList();
        var previousWindow = ordered.Skip(120).Take(120).ToList();

        Kpis.Add(new KpiMetric
        {
            Label = "Total Volume",
            Value = $"£{currentWindow.Sum(x => x.Amount):N0}",
            Delta = FormatDelta(
                currentWindow.Sum(x => x.Amount),
                previousWindow.Sum(x => x.Amount)),
            Positive = IsPositiveDelta(
                currentWindow.Sum(x => x.Amount),
                previousWindow.Sum(x => x.Amount)),
            ProgressPercent = ToProgressPercent(currentWindow.Sum(x => x.Amount), 500_000m, 900_000m)
        });

        Kpis.Add(new KpiMetric
        {
            Label = "Successful Payments",
            Value = currentWindow.Count(x => x.Status == "Successful").ToString(),
            Delta = FormatDelta(
                currentWindow.Count(x => x.Status == "Successful"),
                previousWindow.Count(x => x.Status == "Successful")),
            Positive = IsPositiveDelta(
                currentWindow.Count(x => x.Status == "Successful"),
                previousWindow.Count(x => x.Status == "Successful")),
            ProgressPercent = ToProgressPercent(currentWindow.Count(x => x.Status == "Successful"), 40m, 100m)
        });

        Kpis.Add(new KpiMetric
        {
            Label = "Failed Transactions",
            Value = currentWindow.Count(x => x.Status == "Failed").ToString(),
            Delta = FormatDelta(
                currentWindow.Count(x => x.Status == "Failed"),
                previousWindow.Count(x => x.Status == "Failed")),
            Positive = !IsPositiveDelta(
                currentWindow.Count(x => x.Status == "Failed"),
                previousWindow.Count(x => x.Status == "Failed")),
            ProgressPercent = ToProgressPercent(currentWindow.Count(x => x.Status == "Failed"), 5m, 35m)
        });

        Kpis.Add(new KpiMetric
        {
            Label = "Avg. Processing Time",
            Value = $"{currentWindow.Average(x => x.ProcessingTimeSeconds):N1}s",
            Delta = FormatDelta(
                currentWindow.Average(x => x.ProcessingTimeSeconds),
                previousWindow.Count == 0 ? currentWindow.Average(x => x.ProcessingTimeSeconds) : previousWindow.Average(x => x.ProcessingTimeSeconds)),
            Positive = !IsPositiveDelta(
                currentWindow.Average(x => x.ProcessingTimeSeconds),
                previousWindow.Count == 0 ? currentWindow.Average(x => x.ProcessingTimeSeconds) : previousWindow.Average(x => x.ProcessingTimeSeconds)),
            ProgressPercent = ToProgressPercent(currentWindow.Average(x => x.ProcessingTimeSeconds), 0.5m, 3.8m, inverse: true)
        });

        Kpis.Add(new KpiMetric
        {
            Label = "Fraud Alerts",
            Value = currentWindow.Count(x => x.RiskScore >= 85 || x.DeclineReason == "Suspected fraud").ToString(),
            Delta = FormatDelta(
                currentWindow.Count(x => x.RiskScore >= 85 || x.DeclineReason == "Suspected fraud"),
                previousWindow.Count(x => x.RiskScore >= 85 || x.DeclineReason == "Suspected fraud")),
            Positive = !IsPositiveDelta(
                currentWindow.Count(x => x.RiskScore >= 85 || x.DeclineReason == "Suspected fraud"),
                previousWindow.Count(x => x.RiskScore >= 85 || x.DeclineReason == "Suspected fraud")),
            ProgressPercent = ToProgressPercent(currentWindow.Count(x => x.RiskScore >= 85 || x.DeclineReason == "Suspected fraud"), 2m, 20m)
        });

        var netSettlementCurrent = currentWindow.Where(x => x.Status == "Successful").Sum(x => x.Amount);
        var netSettlementPrevious = previousWindow.Where(x => x.Status == "Successful").Sum(x => x.Amount);
        Kpis.Add(new KpiMetric
        {
            Label = "Net Settlement",
            Value = $"£{netSettlementCurrent:N0}",
            Delta = FormatDelta(netSettlementCurrent, netSettlementPrevious),
            Positive = IsPositiveDelta(netSettlementCurrent, netSettlementPrevious),
            ProgressPercent = ToProgressPercent(netSettlementCurrent, 350_000m, 800_000m)
        });
    }

    private static int ExtractHighestSequence(IEnumerable<TransactionRecord> transactions)
    {
        return transactions
            .Select(x => x.TransactionId.Split('-').LastOrDefault())
            .Select(x => int.TryParse(x, out var value) ? value : 0)
            .DefaultIfEmpty(184200)
            .Max();
    }

    private static bool IsPositiveDelta(decimal current, decimal previous) => current >= previous;

    private static string FormatDelta(decimal current, decimal previous)
    {
        if (previous == 0m)
        {
            return current == 0m ? "0.0%" : "+100.0%";
        }

        var percent = (current - previous) / previous * 100m;
        var sign = percent >= 0 ? "+" : string.Empty;
        return $"{sign}{percent:N1}%";
    }

    private static int ToProgressPercent(decimal value, decimal min, decimal max, bool inverse = false)
    {
        if (max <= min)
        {
            return 50;
        }

        var normalized = (value - min) / (max - min);
        normalized = Math.Clamp(normalized, 0m, 1m);
        if (inverse)
        {
            normalized = 1m - normalized;
        }

        return (int)Math.Round(normalized * 100m);
    }

    public ValueTask DisposeAsync()
    {
        StopLiveMode();
        return ValueTask.CompletedTask;
    }
}
