<aside class="ai-sidebar glass-panel">
    <div class="ai-header">
        <h2>Elyra AI</h2>
        <span class="status-dot">Live</span>
    </div>

    @if (QueryResponse is not null)
    {
        <div class="ai-result-card @(QueryResponse.IsFallback ? "ai-result-fallback" : "ai-result-success")">
            <div class="ai-result-title">AI Result</div>
            <p class="ai-result-prompt">“@QueryResponse.Prompt”</p>
            <p class="ai-result-summary">@QueryResponse.Summary</p>
            @if (QueryResponse.Suggestions.Count > 0)
            {
                <div class="ai-result-suggestions">
                    @foreach (var suggestion in QueryResponse.Suggestions)
                    {
                        <span>@suggestion</span>
                    }
                </div>
            }
        </div>
    }

    <div class="ai-chat-shell">
        <TelerikChat Data="@Conversation"
                     AuthorId="@CurrentUserId"
                     Suggestions="@ChatSuggestions"
                     OnSuggestionClick="HandleSuggestionClickAsync"
                     TextField="@nameof(AiChatMessage.Text)"
                     AuthorIdField="@nameof(AiChatMessage.AuthorId)"
                     AuthorNameField="@nameof(AiChatMessage.AuthorName)"
                     TimestampField="@nameof(AiChatMessage.Timestamp)"
                     Height="320px"
                     OnSendMessage="HandleSendMessageAsync">
        </TelerikChat>
    </div>

    <div class="insights-thread">
        @foreach (var insight in Insights)
        {
            <div class="insight-card @(insight.Severity == "warning" ? "insight-warning" : "insight-info")">
                <div class="insight-head">
                    <span>@insight.Title</span>
                    <span>@insight.Timestamp.ToString("HH:mm:ss")</span>
                </div>
                <p>@insight.Message</p>
            </div>
        }
    </div>

    <div class="ai-actions">
        <TelerikButton ThemeColor="@ThemeConstants.Button.ThemeColor.Primary"
                       Class="ai-action-btn"
                       OnClick="@(async () => await OnSummarizeCurrentView.InvokeAsync())">
            Summarize current view
        </TelerikButton>
        <TelerikButton FillMode="@ThemeConstants.Button.FillMode.Outline"
                       Class="ai-action-btn"
                       OnClick="@(async () => await OnDetectAnomalies.InvokeAsync())">
            Detect anomalies
        </TelerikButton>
    </div>
</aside>

@code {
    private const string CurrentUserId = "user";

    [Parameter]
    public IReadOnlyList<AiChatMessage> Conversation { get; set; } = Array.Empty<AiChatMessage>();

    [Parameter]
    public AiQueryResponse? QueryResponse { get; set; }

    [Parameter]
    public IReadOnlyList<AiInsightMessage> Insights { get; set; } = Array.Empty<AiInsightMessage>();

    [Parameter]
    public EventCallback OnSummarizeCurrentView { get; set; }

    [Parameter]
    public EventCallback OnDetectAnomalies { get; set; }

    [Parameter]
    public IReadOnlyList<string> SuggestedPrompts { get; set; } = Array.Empty<string>();

    [Parameter]
    public EventCallback<string> OnSendPrompt { get; set; }

    private List<string> ChatSuggestions => SuggestedPrompts.ToList();

    private Task HandleSendMessageAsync(ChatSendMessageEventArgs args)
    {
        if (string.IsNullOrWhiteSpace(args.Message))
        {
            return Task.CompletedTask;
        }

        return OnSendPrompt.InvokeAsync(args.Message);
    }

    private Task HandleSuggestionClickAsync(ChatSuggestionClickEventArgs args)
    {
        if (string.IsNullOrWhiteSpace(args.Suggestion))
        {
            return Task.CompletedTask;
        }

        return OnSendPrompt.InvokeAsync(args.Suggestion);
    }
}
