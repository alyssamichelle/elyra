<header class="elyra-topbar glass-panel">
    <div class="brand-wrap">
        <div class="logo-pill">EL</div>
        <div>
            <div class="brand-title">Elyra</div>
            <div class="brand-subline">Real-time transaction intelligence</div>
        </div>
        <span class="telerik-badge">Powered by Telerik Blazor</span>
    </div>

    <div class="topbar-actions">
        <TelerikTextBox Value="@_promptText"
                        ValueChanged="OnPromptChanged"
                        Placeholder="Ask Elyra anything…"
                        Width="100%" />
        <TelerikButton Class="ask-btn"
                       FillMode="@ThemeConstants.Button.FillMode.Outline"
                       OnClick="SubmitPrompt">
            Ask
        </TelerikButton>
        <button class="icon-btn" aria-label="Notifications">🔔</button>
        <div class="avatar">AN</div>
    </div>
</header>

@code {
    private string _promptText = string.Empty;

    [Parameter]
    public EventCallback<string> OnAskPrompt { get; set; }

    private void OnPromptChanged(string value)
    {
        _promptText = value;
    }

    private async Task SubmitPrompt()
    {
        await OnAskPrompt.InvokeAsync(_promptText);
    }
}
